# ─────────────────────────────────────────────────────────────────────────────
# FinAgent — MODO DEV / TESTES
# Este arquivo já funciona sem editar nada (exceto OPENROUTER_API_KEY).
# Só coloque sua chave do OpenRouter e rode: bash start-dev.sh
# ─────────────────────────────────────────────────────────────────────────────

# App
SECRET_KEY=dev-secret-key-nao-usar-em-producao-123456
DEBUG=true
ADMIN_SECRET_KEY=admin123

# URL pública (em dev, acesso local)
BACKEND_PUBLIC_URL=http://localhost:8000

# Database (valores já configurados no docker-compose.dev.yml)
POSTGRES_USER=finagent
POSTGRES_PASSWORD=finagent123
POSTGRES_DB=finagent
DATABASE_URL=postgresql+asyncpg://finagent:finagent123@postgres:5432/finagent

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  ÚNICA COISA QUE VOCÊ PRECISA PREENCHER:
# Sua chave OpenRouter — pegar em https://openrouter.ai/keys
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-COLOQUE-SUA-CHAVE-AQUI

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_API_KEY=dev-evolution-key
EVOLUTION_INSTANCE_NAME=finagent_agent1

# Telegram (opcional — deixar assim para desativar)
TELEGRAM_BOT_TOKEN=

# Frontend / CORS
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
