# ─────────────────────────────────────────────────
# FINAGENT — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────

# App
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=false

# Database
POSTGRES_USER=finagent
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=finagent
DATABASE_URL=postgresql+asyncpg://finagent:your-strong-password-here@postgres:5432/finagent

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────────────────────────────────────────
# OpenRouter (AI)
# Get your key at: https://openrouter.ai/keys
# ─────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model overrides (optional — defaults are set in config.py)
# MODEL_FAST=google/gemini-flash-1.5
# MODEL_STANDARD=anthropic/claude-haiku-4
# MODEL_POWERFUL=anthropic/claude-sonnet-4-5
# MODEL_VISION=openai/gpt-4o
# MODEL_EMBEDDING=openai/text-embedding-3-small

# ─────────────────────────────────────────────────
# Evolution API (WhatsApp Business)
# ─────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=finagent_agent1

# ─────────────────────────────────────────────────
# Telegram (optional)
# Get token from @BotFather on Telegram
# ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
